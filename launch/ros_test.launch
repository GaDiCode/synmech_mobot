<launch>
    <param name="robot_description" command="$(find xacro)/xacro '$(find synmech_mobot)/urdf/robot.urdf.xacro'" />
    
    <param name="use_sim_time" value="false"/> <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" />

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

    <node name="rviz" pkg="rviz" type="rviz" required="true" />
</launch>
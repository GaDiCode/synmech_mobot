<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="inertial_macros.xacro"/>

    <material name="red"><color rgba="0.5 0.125 0.125 1"/></material>
    <material name="matcha"><color rgba="0.52 0.6 0.49 1"/></material>
    <material name="c3"><color rgba="0.785 0.789 0.672 1"/></material>
    <material name="c4"><color rgba="0.96 0.95 0.92 1"/></material>

    <link name="base_footprint"/>
    <link name="base_link"/>
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.012" rpy="0 0 0"/>
    </joint>

    <link name="chasis_link">
        <visual>
            <origin xyz="0 0 0.0425"/>
            <geometry><box size="0.15 0.15 0.085"/></geometry>
            <material name="matcha"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.0425"/>
            <geometry><box size="0.15 0.15 0.085"/></geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.15" y="0.15" z="0.085">
            <origin xyz="0 0 0.0425" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>
    <gazebo reference="chasis_link">
        <material>Gazebo/Grass</material>
    </gazebo>
    <joint name="chasis_base" type="fixed">
        <parent link="base_link"/>
        <child link="chasis_link"/>
        <origin xyz="0 0 0"/>
    </joint>

    <link name="left_wheel_link">
        <visual>
            <geometry><cylinder radius="0.0215" length="0.018"/></geometry>
            <material name="c4"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.0215" length="0.018"/></geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.015" radius="0.0215" length="0.018">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="left_wheel_link">
        <material>Gazebo/Ivory</material>
    </gazebo>
    <joint name="left_wheel_base" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="0 0.084 0.0095" rpy="${-pi/2} 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel_link">
        <visual>
            <geometry><cylinder radius="0.0215" length="0.018"/></geometry>
            <material name="c4"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.0215" length="0.018"/></geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.015" radius="0.0215" length="0.018">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_cylinder>
    </link>
    <gazebo reference="right_wheel_link">
        <material>Gazebo/Ivory</material>
    </gazebo>
    <joint name="right_wheel_base" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="0 -0.084 0.0095" rpy="${pi/2} 0 0"/>
        <axis xyz="0 0 -1"/>
    </joint>

    <link name="caster1_link">
        <visual>
            <geometry><sphere radius="0.006"/></geometry>
            <material name="c3"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.006"/></geometry>
        </collision>
        <xacro:inertial_sphere mass="0.015" radius="0.006">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="caster1_link">
        <material>Gazebo/Sand</material>
    </gazebo>
    <joint name="caster1_base" type="fixed">
        <parent link="base_link"/>
        <child link="caster1_link"/>
        <origin xyz="0.055 0.055 -0.006"/>
    </joint>

    <link name="caster2_link">
        <visual>
            <geometry><sphere radius="0.006"/></geometry>
            <material name="c3"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.006"/></geometry>
        </collision>
        <xacro:inertial_sphere mass="0.015" radius="0.006">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="caster2_link">
        <material>Gazebo/Sand</material>
    </gazebo>
    <joint name="caster2_base" type="fixed">
        <parent link="base_link"/>
        <child link="caster2_link"/>
        <origin xyz="-0.055 0.055 -0.006"/>
    </joint>

    <link name="caster3_link">
        <visual>
            <geometry><sphere radius="0.006"/></geometry>
            <material name="c3"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.006"/></geometry>
        </collision>
        <xacro:inertial_sphere mass="0.015" radius="0.006">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="caster3_link">
        <material>Gazebo/Sand</material>
    </gazebo>
    <joint name="caster3_base" type="fixed">
        <parent link="base_link"/>
        <child link="caster3_link"/>
        <origin xyz="0.055 -0.055 -0.006"/>
    </joint>

    <link name="caster4_link">
        <visual>
            <geometry><sphere radius="0.006"/></geometry>
            <material name="c3"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.006"/></geometry>
        </collision>
        <xacro:inertial_sphere mass="0.015" radius="0.006">
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </xacro:inertial_sphere>
    </link>
    <gazebo reference="caster4_link">
        <material>Gazebo/Sand</material>
    </gazebo>
    <joint name="caster4_base" type="fixed">
        <parent link="base_link"/>
        <child link="caster4_link"/>
        <origin xyz="-0.055 -0.055 -0.006"/>
    </joint>

    <gazebo>
        <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
            <updateRate>100</updateRate>
            <leftJoint>left_wheel_base</leftJoint>
            <rightJoint>right_wheel_base</rightJoint>
            <wheelSeparation>0.168</wheelSeparation>
            <wheelDiameter>0.043</wheelDiameter>
            <wheelAcceleration>1.0</wheelAcceleration>
            <wheelTorque>20</wheelTorque>
            <commandTopic>cmd_vel</commandTopic>
            <odometryTopic>odom</odometryTopic>
            <odometryFrame>odom</odometryFrame>
            <robotBaseFrame>base_footprint</robotBaseFrame>
            <publishWheelTF>true</publishWheelTF>
            <publishOdomTF>true</publishOdomTF>
        </plugin>
    </gazebo>
</robot>